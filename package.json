{
  "name": "playwrighttypescript",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "pretest": "ts-node utilities/generate-allure-env.ts",
    "test": "dotenvx run --quiet -- npx playwright test",
    "allure:report": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "agent:setup": "powershell ./agent-manager.ps1 -Command setup",
    "agent:start": "powershell ./agent-manager.ps1 -Command start",
    "agent:stop": "powershell ./agent-manager.ps1 -Command stop",
    "agent:status": "powershell ./agent-manager.ps1 -Command status",
    "agent:logs": "powershell ./agent-manager.ps1 -Command logs",
    "agent:clean": "powershell ./agent-manager.ps1 -Command clean",
    "test:distributed": "ts-node utilities/distributed-test-agent.ts",
    "test:call-center": "dotenvx run --quiet -- npx playwright test --project=call-center",
    "test:xml-api": "dotenvx run --quiet -- npx playwright test --project=xml-api",
    "test:json-api": "dotenvx run --quiet -- npx playwright test --project=json-api"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@types/node": "^24.0.14",
    "@types/nodemailer": "^7.0.2",
    "@types/uuid": "^10.0.0",
    "@types/xmldom": "^0.1.34",
    "allure-commandline": "^2.34.1",
    "allure-js-commons": "^3.3.2",
    "allure-playwright": "^3.3.2",
    "sonar-scanner": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@faker-js/faker": "^10.0.0",
    "dotenv": "^17.2.0",
    "jsonpath-plus": "^10.3.0",
    "log4js": "^6.9.1",
    "nodemailer": "^7.0.6",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5",
    "xml2js": "^0.6.2",
    "xmldom": "^0.6.0",
    "xpath": "^0.0.34"
  }
}
